(footprint "TO-5_BPW20RF"
  (version 20221018)
  (generator pcbnew)
  (layer "F.Cu")
  (descr "BPW20RF Silicon Photodiode, TO-5, 2 leads, pitch 5.08mm, body dia 8.13mm")
  (tags "TO-5 photodiode BPW20RF through-hole")
  (attr through_hole)

  (fp_text reference "D1"
    (at 0 -5.8 0)
    (layer "F.SilkS")
    (effects (font (size 1.27 1.27) (thickness 0.15)))
  )

  (fp_text value "BPW20RF"
    (at 0 5.8 0)
    (layer "F.Fab")
    (effects (font (size 1.27 1.27) (thickness 0.15)))
  )

  (fp_circle
    (center 0 0)
    (end 4.065 0)
    (stroke (width 0.1) (type solid))
    (fill none)
    (layer "F.Fab")
  )

  (fp_circle
    (center 0 0)
    (end 4.065 0)
    (stroke (width 0.12) (type solid))
    (fill none)
    (layer "F.SilkS")
  )

  (fp_line
    (start -4.315 -0.75)
    (end -4.315 0.75)
    (stroke (width 0.12) (type solid))
    (layer "F.SilkS")
  )

  (fp_rect
    (start -5.05 -5.05)
    (end 5.05 5.05)
    (stroke (width 0.05) (type solid))
    (fill none)
    (layer "F.CrtYd")
  )

  (pad "1" thru_hole rect
    (at -2.54 0)
    (size 1.8 1.8)
    (drill 0.9)
    (layers "*.Cu" "*.Mask")
  )

  (pad "2" thru_hole circle
    (at 2.54 0)
    (size 1.8 1.8)
    (drill 0.9)
    (layers "*.Cu" "*.Mask")
  )
)
